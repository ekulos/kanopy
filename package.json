{
  "name": "kanopy",
  "version": "0.1.5",
  "private": true,
  "scripts": {
    "dev": "prisma generate --schema=prisma/schema.sqlite.prisma && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate --schema=prisma/schema.sqlite.prisma",
    "db:push": "prisma db push --schema=prisma/schema.sqlite.prisma",
    "db:migrate": "prisma migrate dev --schema=prisma/schema.sqlite.prisma",
    "db:studio": "prisma studio --schema=prisma/schema.sqlite.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "release": "release-it",
    "release:minor": "release-it minor",
    "release:major": "release-it major"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^5.22.0",
    "@tanstack/react-query": "^5.62.9",
    "@uiw/react-md-editor": "^4.0.11",
    "autoprefixer": "^10.4.27",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "next": "15.0.3",
    "next-auth": "^5.0.0-beta.25",
    "next-intl": "^4.8.3",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/node": "^20",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "15.0.3",
    "postcss": "^8",
    "prisma": "^5.22.0",
    "release-it": "^19.2.4",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
